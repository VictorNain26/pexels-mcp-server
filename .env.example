# ---------------------------------------------------------------------------
# pexels-mcp-server environment template. Copy to `.env` for local dev.
# `.env` is gitignored; `.env.example` is the only one that gets committed.
# ---------------------------------------------------------------------------

# Pexels API key. Get one at https://www.pexels.com/api/
# stdio transport: required.
# streamable-http transport: optional fallback for callers that omit the
#   X-Pexels-Api-Key header. Leave unset in multi-tenant hosted deployments.
PEXELS_API_KEY=

# Transport: `stdio` (default, for local MCP clients) or `streamable-http`
# (hosted HTTP endpoint at /mcp). claude.ai custom connectors require HTTP.
TRANSPORT=stdio

# ---------------------------------------------------------------------------
# streamable-http only - ignored when TRANSPORT=stdio
# ---------------------------------------------------------------------------

# Bind address. 127.0.0.1 for local dev, 0.0.0.0 inside a container.
HOST=127.0.0.1

# Listening port. Koyeb / Fly inject this automatically; default is 8000.
PORT=8000

# Shared Bearer token gating /mcp. REQUIRED in streamable-http mode - the
# server exits with code 2 if unset. Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN=

# Set to `1` to allow streamable-http to boot without MCP_AUTH_TOKEN.
# Local development only. NEVER set in production.
MCP_ALLOW_UNAUTHED=

# Comma-separated allowlist for the HTTP Host header (DNS rebinding
# protection per MCP spec 2025-06-18). Supports the `host:*` wildcard.
# Unset = accept any Host (Bearer auth is the gate). On Koyeb, set this to
# your service domain, e.g. MCP_ALLOWED_HOSTS=pexels-mcp.koyeb.app
MCP_ALLOWED_HOSTS=

# Log level: DEBUG | INFO (default) | WARNING | ERROR
LOG_LEVEL=INFO

# Log format. `text` (default for stdio) or `json` (default for
# streamable-http, recommended for Koyeb / Fly / Cloud Run log drains).
LOG_FORMAT=
