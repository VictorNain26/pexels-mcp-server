# ---------------------------------------------------------------------------
# pexels-mcp-server environment template. Copy to `.env` for local dev.
# `.env` is gitignored; `.env.example` is the only file that gets committed.
# ---------------------------------------------------------------------------
#
# The server runs in ONE of two modes, picked by TRANSPORT:
#   stdio            -> local clients (Claude Desktop, Claude Code, Cursor)
#   streamable-http  -> hosted endpoint usable by claude.ai web custom
#                       connectors and any MCP HTTP client
#
# OAuth 2.1 (RFC 9728) is REQUIRED in streamable-http mode. The server is
# its own Authorization Server + Resource Server in one process.

TRANSPORT=stdio

# ---------------------------------------------------------------------------
# Pexels API key
# ---------------------------------------------------------------------------
# Get one at https://www.pexels.com/api/
#
# - stdio: REQUIRED here (tools call Pexels with this key on every request).
# - streamable-http: OPTIONAL server-side fallback. Multi-tenant deployments
#   leave this UNSET; each caller sends its own key via the
#   `X-Pexels-Api-Key` header so they pay their own Pexels quota.
PEXELS_API_KEY=

# ---------------------------------------------------------------------------
# streamable-http only - REQUIRED when TRANSPORT=streamable-http
# ---------------------------------------------------------------------------

# Public HTTPS URL of this service (no trailing slash). Used as the OAuth
# issuer_url AND the RFC 9728 resource_server_url, so it MUST match the
# host clients see (claude.ai sends the resource indicator on /authorize,
# the AS metadata documents reference this URL, and the WWW-Authenticate
# header on 401 points to {URL}/.well-known/oauth-protected-resource).
#
# On Koyeb, set this to your service domain, e.g.:
#   MCP_SERVER_URL=https://pexels-mcp-tomia-9e578486.koyeb.app
# Once a custom domain is attached, switch to it:
#   MCP_SERVER_URL=https://pexels-mcp.example.com
MCP_SERVER_URL=

# Shared passcode users type on the /login page during the OAuth flow.
# Generate with: openssl rand -hex 16
# Share it once with each MCP client owner you trust; rotate by changing
# this value (existing tokens stay valid until they expire, ~1h).
MCP_AUTH_PASSCODE=

# ---------------------------------------------------------------------------
# Networking and observability (HTTP mode)
# ---------------------------------------------------------------------------

# Bind address. 127.0.0.1 for local dev, 0.0.0.0 inside a container.
HOST=127.0.0.1

# Listening port. Koyeb / Fly inject this automatically.
PORT=8000

# Comma-separated allowlist for the HTTP Host header (DNS rebinding
# protection per MCP spec 2025-06-18). Supports the `host:*` wildcard.
# Unset = accept any Host (OAuth + Bearer validation is the gate).
# On Koyeb, set this to `{{ KOYEB_PUBLIC_DOMAIN }}` to lock the Host.
MCP_ALLOWED_HOSTS=

# Log level: DEBUG | INFO (default) | WARNING | ERROR
LOG_LEVEL=INFO

# Log format. `text` (default for stdio) or `json` (default for
# streamable-http, recommended for Koyeb / Fly / Cloud Run log drains).
LOG_FORMAT=
